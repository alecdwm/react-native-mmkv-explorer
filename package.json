{
  "name": "react-native-mmkv-explorer",
  "version": "0.0.6",
  "packageManager": "pnpm@10.33.1",
  "description": "An interactive in-app dev tool for exploring react-native-mmkv storage",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf lib",
    "prepublishOnly": "pnpm clean && pnpm build",
    "bump": "pnpm version patch",
    "bump:minor": "pnpm version minor",
    "bump:major": "pnpm version major",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "prepare": "husky"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "keywords": [
    "react-native",
    "mmkv",
    "storage",
    "devtools",
    "debug",
    "explorer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alecdwm/react-native-mmkv-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/alecdwm/react-native-mmkv-explorer/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.65.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "react-native-mmkv": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --no-errors-on-unmatched"
    ]
  }
}
